{
  "name": "@iivgll4/lema",
  "version": "0.0.1",
  "description": "A local, self-improving agentic CLI for local LLMs. It works in your repo, chats, and grows its own verified skills.",
  "type": "module",
  "bin": {
    "lema": "dist/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --import tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "node --import tsx/esm --test 'tests/**/*.test.ts'",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "llm",
    "agent",
    "cli",
    "local",
    "lm-studio",
    "ollama",
    "self-improving",
    "skills",
    "coding-agent"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
